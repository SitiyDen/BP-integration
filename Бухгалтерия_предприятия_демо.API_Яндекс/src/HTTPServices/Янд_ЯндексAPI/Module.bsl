КонецФункции

Функция ПолучениеСпискаРасчетовСКонтрагентамиПолучить(Запрос)
	
	СписокКонтрагентов  = Запрос.ПараметрыЗапроса.Получить("parties");
	НачалоПериода = Запрос.ПараметрыЗапроса.Получить("from_date");
	КонецПериода  = Запрос.ПараметрыЗапроса.Получить("to_date");
	
	СписокКонтрагентов = API_СлужебныйСервер.СтрокаПараметровВМассив(СписокКонтрагентов);
	
	Если НачалоПериода = Неопределено Тогда
		Ответ = API_СлужебныйСервер.Ответ(400, "Не указана дата начала периода");
		Возврат Ответ;
	КонецЕсли;
	
	НачалоПериода = API_СлужебныйСервер.ПреобразоватьСтрокуВДату1С(НачалоПериода);
	
	Если КонецПериода = Неопределено Тогда
		КонецПериода = ТекущаяДатаСеанса();
	Иначе
		КонецПериода = API_СлужебныйСервер.ПреобразоватьСтрокуВДату1С(КонецПериода);
	КонецЕсли;
	
	Попытка
		JSONСтрока = API_Контрагенты.ПолучитьРасчетыСКонтрагентами(СписокКонтрагентов, НачалоПериода, КонецПериода);
		Ответ = API_СлужебныйСервер.Ответ(200, JSONСтрока);
	Исключение
		Ответ = API_СлужебныйСервер.Ответ(500, ОписаниеОшибки());
	КонецПопытки;
	
	Возврат Ответ;
КонецФункции

