#Область ПрограммныйИнтерфейс

// Возвращает список счетов бухгалтерского учета в формате JSON для внешнего использования
//
// Возвращаемое значение:
//   Строка - JSON-строка, содержащая массив структур с данными счетов:
//           * Account - Строка - код счета
//           * AccountName - Строка - наименование счета
//           * AccountFeats - Строка - признаки счета через запятую (Количественный, УчетПоПодразделениям, Валютный, НалоговыйУчет)
//           * SubConto - Строка - виды субконто через запятую
Функция ПолучитьСчета() Экспорт
	
	Счета = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХозрасчетныйВидыСубконто.Ссылка КАК Ссылка,
		|	ХозрасчетныйВидыСубконто.Ссылка.Код КАК Код,
		|	ХозрасчетныйВидыСубконто.Ссылка.Наименование КАК Наименование,
		|	ХозрасчетныйВидыСубконто.Ссылка.Валютный КАК Валютный,
		|	ХозрасчетныйВидыСубконто.Ссылка.Количественный КАК Количественный,
		|	ХозрасчетныйВидыСубконто.Ссылка.УчетПоПодразделениям КАК УчетПоПодразделениям,
		|	ХозрасчетныйВидыСубконто.Ссылка.НалоговыйУчет КАК НалоговыйУчет,
		|	ХозрасчетныйВидыСубконто.ВидСубконто.Наименование КАК ВидСубконто,
		|	ХозрасчетныйВидыСубконто.Ссылка.Забалансовый КАК Забалансовый,
		|	ХозрасчетныйВидыСубконто.Ссылка.Вид КАК Вид
		|ИЗ
		|	ПланСчетов.Хозрасчетный.ВидыСубконто КАК ХозрасчетныйВидыСубконто
		|
		|УПОРЯДОЧИТЬ ПО
		|	Код
		|ИТОГИ ПО
		|	Ссылка";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСсылка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаСсылка.Следующий() Цикл
		
		Структура = Новый Структура;
		Структура.Вставить("Account", ВыборкаСсылка.Код);
		Структура.Вставить("AccountName", ВыборкаСсылка.Наименование);
		
		// Формирование признаков
		МассивПризнаков = Новый Массив;
		
		Если ВыборкаСсылка.Количественный Тогда
			МассивПризнаков.Добавить("Количественный");
		КонецЕсли;
		
		Если ВыборкаСсылка.УчетПоПодразделениям Тогда
			МассивПризнаков.Добавить("УчетПоПодразделениям");
		КонецЕсли;
		
		Если ВыборкаСсылка.Валютный Тогда
			МассивПризнаков.Добавить("Валютный");
		КонецЕсли;
		
		Если ВыборкаСсылка.НалоговыйУчет Тогда
			МассивПризнаков.Добавить("НалоговыйУчет");
		КонецЕсли;
		
		Структура.Вставить("AccountFeats", СтрСоединить(МассивПризнаков, ", "));
		Структура.Вставить("AccountType", Строка(ВыборкаСсылка.Вид));
		Структура.Вставить("NonBalance",  ВыборкаСсылка.Забалансовый);
		
		// Формирование субконто
		ВыборкаДетальныеЗаписи = ВыборкаСсылка.Выбрать();
		МассивСубконто = Новый Массив;
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			МассивСубконто.Добавить(ВыборкаДетальныеЗаписи.ВидСубконто);
		КонецЦикла;
		
		Структура.Вставить("SubConto", СтрСоединить(МассивСубконто, ", "));
		Счета.Добавить(Структура);
		
	КонецЦикла;
	
	JSONСтрока = API_СлужебныйСервер.ПреобразоватьВJSON(Счета);
	Возврат JSONСтрока;
	
КонецФункции

// Возвращает остатки по счетам бухгалтерского учета за указанный период в формате JSON.
//
// Параметры:
//   СписокСчетов - Массив из Строка - список счетов для выборки
//   НачалоПериода - Дата - начало периода анализа
//   КонецПериода - Дата - конец периода анализа
//   Субконто1 - Массив из Строка - значение первого вида субконто для фильтрации
//   Субконто2 - Массив из Строка - значение второго вида субконто для фильтрации
//   Субконто3 - Массив из Строка - значение третьего вида субконто для фильтрации
//   Организации - Массив из СправочникСсылка.Организации - организации для выборки
//   ПоказыватьСубСчета - Булево - необходимость включения субсчетов в выборку
//   ДетализацияСубконто - Число- уровень детализации по субконто
//
// Возвращаемое значение:
//   Строка - JSON-строка с массивом остатков по счетам
Функция ПолучитьОстаткиСчетовJSON(СписокСчетов, НачалоПериода, КонецПериода, Субконто1, Субконто2, Субконто3, 
									Организации, ПоказыватьСубСчета, ДетализацияСубконто) Экспорт
	
	ОрганизацииДляJSON = Новый Массив;
	
	Запрос = СформироватьЗапросОСВ(НачалоПериода, КонецПериода, СписокСчетов, Субконто1, Субконто2, Субконто3, 
									Организации, ПоказыватьСубСчета, ДетализацияСубконто);
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаОрганизация = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ЕстьСубконто1 = РезультатЗапроса.Колонки.Найти("Субконто1") <> Неопределено;
	ЕстьСубконто2 = РезультатЗапроса.Колонки.Найти("Субконто2") <> Неопределено;
	ЕстьСубконто3 = РезультатЗапроса.Колонки.Найти("Субконто3") <> Неопределено;
	
	Пока ВыборкаОрганизация.Следующий() Цикл
		
		СтруктураОрганизация = Новый Структура;
		СтруктураОрганизация.Вставить("Organization", Строка(ВыборкаОрганизация.Организация));
	
		ВыборкаДетальныеЗаписи = ВыборкаОрганизация.Выбрать();
	
		МассивДетальныхЗаписей = Новый Массив;
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			СтруктураДетальныхЗаписей = СформироватьСтруктуруДетальныхЗаписей(ВыборкаДетальныеЗаписи, ЕстьСубконто1, ЕстьСубконто2, ЕстьСубконто3);
			МассивДетальныхЗаписей.Добавить(СтруктураДетальныхЗаписей);
			
		КонецЦикла;
		
		СтруктураОрганизация.Вставить("Records", МассивДетальныхЗаписей);
		ОрганизацииДляJSON.Добавить(СтруктураОрганизация);
		
	КонецЦикла;
	
	JSONСтрока = API_СлужебныйСервер.ПреобразоватьВJSON(ОрганизацииДляJSON);
	Возврат JSONСтрока;
	
КонецФункции

// Возвращает ссылки на счета бухгалтерского учета по заданным кодам.
//
// Параметры:
//   МассивКодов - Массив из Строка, Число - коды счетов для поиска
//
// Возвращаемое значение:
//   Массив из ПланСчетовСсылка.Хозрасчетный - ссылки на найденные счета
Функция ПреобразоватьСтрокиСчетаВСсылки(МассивКодов) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Хозрасчетный.Ссылка КАК Ссылка
		|ИЗ
		|	ПланСчетов.Хозрасчетный КАК Хозрасчетный
		|ГДЕ
		|	Хозрасчетный.Код В(&Код)";
	
	Запрос.УстановитьПараметр("Код", МассивКодов);
	
	Результат = Запрос.Выполнить().Выгрузить();
	МассивСчетов = Результат.ВыгрузитьКолонку("Ссылка");
	
	Возврат МассивСчетов;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует структуру детальных записей бухгалтерского счета с оборотами и остатками.
//
// Параметры:
//   Выборка - Произвольный - выборка с данными счета, остатками и оборотами
//
// Возвращаемое значение:
//   Структура:
Функция СформироватьСтруктуруДетальныхЗаписей(Выборка, ЕстьСубконто1, ЕстьСубконто2, ЕстьСубконто3)
	
	Структура = Новый Структура;
	
	Структура.Вставить("Account", Строка(Выборка.Счет));
	Структура.Вставить("AccountName", Выборка.СчетНаименование);
	Структура.Вставить("Currency", Строка(Выборка.Валюта));
	
	Если ЕстьСубконто1 Тогда	
		Структура.Вставить("subconto1", Строка(Выборка.Субконто1));
		
		ТипЗначения = ТипЗнч(Выборка.Субконто1);
		Если ОбщегоНазначения.ЭтоСсылка(ТипЗначения) Тогда
			Структура.Вставить("subconto1ref", ПолучитьВнешнююНавигационнуюСсылку(, ПолучитьНавигационнуюСсылку(Выборка.Субконто1)));
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЕстьСубконто2 Тогда	
		Структура.Вставить("subconto2", Строка(Выборка.Субконто2));
		
		ТипЗначения = ТипЗнч(Выборка.Субконто2);
		Если ОбщегоНазначения.ЭтоСсылка(ТипЗначения) Тогда
			Структура.Вставить("subcont21ref", ПолучитьВнешнююНавигационнуюСсылку(, ПолучитьНавигационнуюСсылку(Выборка.Субконто2)));
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЕстьСубконто3 Тогда
		Структура.Вставить("subconto3", Строка(Выборка.Субконто3));
		
		ТипЗначения = ТипЗнч(Выборка.Субконто3);
		Если ОбщегоНазначения.ЭтоСсылка(ТипЗначения) Тогда
			Структура.Вставить("subconto3ref", ПолучитьВнешнююНавигационнуюСсылку(, ПолучитьНавигационнуюСсылку(Выборка.Субконто3)));
		КонецЕсли;
		
	КонецЕсли;

	Структура.Вставить("BalanceDebitInitial", Выборка.СуммаНачальныйОстатокДт);
	Структура.Вставить("BalanceCreditInitial", Выборка.СуммаНачальныйОстатокКт);
	Структура.Вставить("TurnoverDebit", Выборка.СуммаОборотДт);
	Структура.Вставить("TurnoverCredit", Выборка.СуммаОборотКт);
	Структура.Вставить("BalanceDebitFinal", Выборка.СуммаКонечныйОстатокДт);
	Структура.Вставить("BalanceCreditFinal", Выборка.СуммаКонечныйОстатокКт);
	Структура.Вставить("CurrencyBalanceDebitInitial", Выборка.ВалютнаяСуммаНачальныйОстатокДт);
	Структура.Вставить("CurrencyBalanceCreditInitial", Выборка.ВалютнаяСуммаНачальныйОстатокКт);
	Структура.Вставить("CurrencyTurnoverDebit", Выборка.ВалютнаяСуммаОборотДт);
	Структура.Вставить("CurrencyTurnoverCredit", Выборка.ВалютнаяСуммаОборотКт);
	Структура.Вставить("CurrencyBalanceDebitFinal", Выборка.ВалютнаяСуммаКонечныйОстатокДт);
	Структура.Вставить("CurrencyBalanceCreditFinal", Выборка.ВалютнаяСуммаКонечныйОстатокКт);

	Возврат Структура;
	
КонецФункции

// Формирует текст запроса для получения оборотно-сальдовой ведомости по счетам бухгалтерского учета за период с заданными условиями отбора.
//
// Параметры:
//   НачалоПериода - Дата - начало периода выборки
//   КонецПериода - Дата - конец периода выборки
//   СписокСчетов - Массив из Строка - список кодов счетов для отбора
//   Субконто1 - Массив из Строка - список значений первого субконто для фильтрации
//   Субконто2 - Массив из Строка - список значений второго субконто для фильтрации
//   Субконто3 - Массив из Строка - список значений третьего субконто для фильтрации
//   Организации - Массив из Строка - список наименований организаций для фильтрации
//   ПоказыватьСубСчета - Булево - признак включения в выборку субсчетов по иерархии
//   ДетализацияСубконто - Число - уровень детализации по субконто (0-без субконто, 1-первое, 2-второе, 3-третье)
//
// Возвращаемое значение:
//   Строка - текст сформированного запроса
Функция СформироватьЗапросОСВ(НачалоПериода, КонецПериода, СписокСчетов, Субконто1, Субконто2, Субконто3, Организации, ПоказыватьСубСчета, ДетализацияСубконто)
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ХозрасчетныйОстаткиИОбороты.Счет КАК Счет,
	|	ХозрасчетныйОстаткиИОбороты.Счет.Наименование КАК СчетНаименование,
	|	ХозрасчетныйОстаткиИОбороты.Субконто1 КАК Субконто1,
	|	ХозрасчетныйОстаткиИОбороты.Субконто2 КАК Субконто2,
	|	ХозрасчетныйОстаткиИОбороты.Субконто3 КАК Субконто3,
	|	ХозрасчетныйОстаткиИОбороты.Организация КАК Организация,
	|	ХозрасчетныйОстаткиИОбороты.Валюта КАК Валюта,
	|	ХозрасчетныйОстаткиИОбороты.СуммаНачальныйОстатокДт КАК СуммаНачальныйОстатокДт,
	|	ХозрасчетныйОстаткиИОбороты.СуммаНачальныйОстатокКт КАК СуммаНачальныйОстатокКт,
	|	ХозрасчетныйОстаткиИОбороты.СуммаОборотДт КАК СуммаОборотДт,
	|	ХозрасчетныйОстаткиИОбороты.СуммаОборотКт КАК СуммаОборотКт,
	|	ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт КАК СуммаКонечныйОстатокДт,
	|	ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокКт КАК СуммаКонечныйОстатокКт,
	|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаНачальныйОстатокДт КАК ВалютнаяСуммаНачальныйОстатокДт,
	|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаНачальныйОстатокКт КАК ВалютнаяСуммаНачальныйОстатокКт,
	|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаОборотДт КАК ВалютнаяСуммаОборотДт,
	|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаОборотКт КАК ВалютнаяСуммаОборотКт,
	|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаКонечныйОстатокДт КАК ВалютнаяСуммаКонечныйОстатокДт,
	|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаКонечныйОстатокКт КАК ВалютнаяСуммаКонечныйОстатокКт
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&НачалоПериода, &КонецПериода,,, Счет В (&СписокСчетов),, %1) КАК
	|		ХозрасчетныйОстаткиИОбороты
	|ИТОГИ
	|ПО
	|	Организация";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("СписокСчетов", СписокСчетов);
	
	Если ПоказыватьСубСчета Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Счет В (&СписокСчетов)", "Счет В ИЕРАРХИИ (&СписокСчетов)");
	КонецЕсли;
	
	// Детализация субконто
	Если ДетализацияСубконто = 0 Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ХозрасчетныйОстаткиИОбороты.Субконто1 КАК Субконто1,", "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ХозрасчетныйОстаткиИОбороты.Субконто2 КАК Субконто2,", "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ХозрасчетныйОстаткиИОбороты.Субконто3 КАК Субконто3,", "");
	КонецЕсли;
	
	Если ДетализацияСубконто = 1 Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ХозрасчетныйОстаткиИОбороты.Субконто2 КАК Субконто2,", "");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ХозрасчетныйОстаткиИОбороты.Субконто3 КАК Субконто3,", "");
	КонецЕсли;
	
	Если ДетализацияСубконто = 2 Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ХозрасчетныйОстаткиИОбороты.Субконто3 КАК Субконто3,", "");
	КонецЕсли;	
	
	Условия = "";
	
	Если Организации.Количество() > 0 Тогда
		Условия = Условия + " Организация.Наименование В (&Организации)";
		Запрос.УстановитьПараметр("Организации", Организации);
	КонецЕсли;
	
	Если Субконто1.Количество() > 0 Тогда
		Если Условия <> "" Тогда
			Условия = Условия + " И ";
		КонецЕсли;
		Условия = Условия + "Субконто1.Наименование В (&Субконто1)";
		Запрос.УстановитьПараметр("Субконто1", Субконто1);
	КонецЕсли;
	
	Если Субконто2.Количество() > 0 Тогда
		Если Условия <> "" Тогда
			Условия = Условия + " И ";
		КонецЕсли;
		Условия = Условия + "Субконто2.Наименование В (&Субконто2)";
		Запрос.УстановитьПараметр("Субконто2", Субконто2);
	КонецЕсли;
	
	Если Субконто3.Количество() > 0 Тогда
		Если Условия <> "" Тогда
			Условия = Условия + " И ";
		КонецЕсли;
		Условия = Условия + "Субконто3.Наименование В (&Субконто3)";
		Запрос.УстановитьПараметр("Субконто3", Субконто3);
	КонецЕсли;
	
	Если Условия = "" Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%1", "");
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%1", Условия);
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	
	Возврат Запрос;
		
КонецФункции


#КонецОбласти
