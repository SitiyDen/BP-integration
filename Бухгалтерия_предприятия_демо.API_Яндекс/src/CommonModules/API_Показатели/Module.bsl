// Возвращаемое значение:
//   Строка - JSON-строка с показателями монитора руководителя
Функция ПоказателиМонитораРуководителя() Экспорт

	УстановитьПривилегированныйРежим(Истина);
	ПубликуемыеДанные = ВнешнийПрограммныйИнтерфейс.ПубликуемыеДанныеМонитора();
	УстановитьПривилегированныйРежим(Ложь);
	
	JSONСтрока = API_СлужебныйСервер.ПреобразоватьВJSON(ПубликуемыеДанные);
	
	Возврат JSONСтрока;
	
КонецФункции

