#Область СлужебныйПрограммныйИнтерфейс

// Возвращает список складов указанных типов в формате JSON.
//
// Параметры:
//   ТипыСкладов - Массив из ПеречислениеСсылка.ТипыСкладов - типы складов для отбора
//   СписокОтветственных - Массив из Строка - ФИО ответственных лиц для отбора
//
// Возвращаемое значение:
//   Строка - JSON-строка с массивом структур:
//     * Name - Строка - наименование склада
//     * Address - Строка - адрес склада
//     * Type - Строка - тип склада
//     * Responsible - Строка - ФИО ответственного лица
Функция ПолучитьСклады(ТипыСкладов, СписокОтветственных) Экспорт
	
	Склады = Новый Массив;
	
	Запрос = Новый Запрос;
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	Склады.Ссылка КАК Ссылка,
	|	Склады.Наименование КАК Наименование,
	|	Склады.ТипСклада КАК ТипСклада,
	|	ОтветственныеЛицаСрезПоследних.ФизическоеЛицо.ФИО КАК ФИО
	|ИЗ
	|	Справочник.Склады КАК Склады
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОтветственныеЛица.СрезПоследних КАК ОтветственныеЛицаСрезПоследних
	|		ПО Склады.Ссылка = ОтветственныеЛицаСрезПоследних.СтруктурнаяЕдиница
	|ГДЕ
	|	Склады.ТипСклада В (&ТипыСкладов)";
	
	Запрос.УстановитьПараметр("ТипыСкладов", ТипыСкладов);

	Если СписокОтветственных.Количество() > 0 Тогда
		ТекстЗапроса = ТекстЗапроса + "И ОтветственныеЛицаСрезПоследних.ФизическоеЛицо.ФИО В (&СписокОтветственных)";
		Запрос.УстановитьПараметр("СписокОтветственных", СписокОтветственных);
	КонецЕсли;

	Запрос.Текст = ТекстЗапроса;

	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Адрес = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ВыборкаДетальныеЗаписи.Ссылка, Справочники.ВидыКонтактнойИнформации.АдресСклада, ,Истина);
		
		Структура = Новый Структура;
		Структура.Вставить("Name", ВыборкаДетальныеЗаписи.Наименование);
		Структура.Вставить("Address", Адрес);
		Структура.Вставить("Type", Строка(ВыборкаДетальныеЗаписи.ТипСклада));
		Структура.Вставить("Responsible", Строка(ВыборкаДетальныеЗаписи.ФИО));  
		
		Склады.Добавить(Структура);
		
	КонецЦикла;	
		
	JSONСтрока = API_СлужебныйСервер.ПреобразоватьВJSON(Склады);
	Возврат JSONСтрока;
	
КонецФункции

// Возвращает остатки товаров на указанных складах в формате JSON
//
// Параметры:
//   СписокНазванийСкладов - Массив из Строка - наименования складов для фильтрации
//   НоменклатураСписок - Массив из Строка - наименования номенклатуры для фильтрации
//   СписокАртикулов - Массив из Строка - артикулы для фильтрации
//   Дата - Дата - дата получения остатков
//
// Возвращаемое значение:
//   Строка - JSON-строка с остатками по складам
Функция ПолучитьОстаткиПоТоварамНаСкладе(СписокНазванийСкладов, НоменклатураСписок, СписокАртикулов, Дата) Экспорт
	
	Склады = Новый Массив;
	
	Запрос = Новый Запрос;
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ХозрасчетныйОстатки.Субконто1 ССЫЛКА Справочник.Номенклатура
		|			ТОГДА ХозрасчетныйОстатки.Субконто1
		|		КОГДА ХозрасчетныйОстатки.Субконто2 ССЫЛКА Справочник.Номенклатура
		|			ТОГДА ХозрасчетныйОстатки.Субконто2
		|		ИНАЧЕ NULL
		|	КОНЕЦ КАК Номенклатура,
		|	ВЫБОР
		|		КОГДА ХозрасчетныйОстатки.Субконто1 ССЫЛКА Справочник.Номенклатура
		|			ТОГДА ХозрасчетныйОстатки.Субконто1.ЕдиницаИзмерения
		|		КОГДА ХозрасчетныйОстатки.Субконто2 ССЫЛКА Справочник.Номенклатура
		|			ТОГДА ХозрасчетныйОстатки.Субконто2.ЕдиницаИзмерения
		|		ИНАЧЕ NULL
		|	КОНЕЦ КАК ЕдиницаИзмерения,
		|	ВЫБОР
		|		КОГДА ХозрасчетныйОстатки.Субконто1 ССЫЛКА Справочник.Номенклатура
		|			ТОГДА ХозрасчетныйОстатки.Субконто1.Артикул
		|		КОГДА ХозрасчетныйОстатки.Субконто2 ССЫЛКА Справочник.Номенклатура
		|			ТОГДА ХозрасчетныйОстатки.Субконто2.Артикул
		|		ИНАЧЕ NULL
		|	КОНЕЦ КАК Артикул,
		|	ХозрасчетныйОстатки.КоличествоОстаток КАК Количество,
		|	ХозрасчетныйОстатки.Субконто3 КАК Склад,
		|	ХозрасчетныйОстатки.СуммаОстаток КАК Сумма,
		|	ВЫБОР
		|		КОГДА ХозрасчетныйОстатки.КоличествоОстаток <> 0
		|			ТОГДА ХозрасчетныйОстатки.СуммаОстаток / ХозрасчетныйОстатки.КоличествоОстаток
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Цена
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Остатки(&Дата,,,&ПараметрыВТ) КАК ХозрасчетныйОстатки
		|ГДЕ
		|	(ХозрасчетныйОстатки.Субконто1 ССЫЛКА Справочник.Номенклатура
		|	ИЛИ ХозрасчетныйОстатки.Субконто2 ССЫЛКА Справочник.Номенклатура)
		|	И ХозрасчетныйОстатки.КоличествоОстаток <> 0
		|	И ХозрасчетныйОстатки.Субконто3 ССЫЛКА Справочник.Склады
		|ИТОГИ
		|ПО
		|	Склад";
	
	УсловиеВТ = "";
	
	Если СписокНазванийСкладов.Количество() > 0 Тогда
		УсловиеВТ = "Субконто3.Наименование В (&СписокНазванийСкладов)";
	КонецЕсли;
	
	Если СписокАртикулов.Количество() > 0 Тогда
		Если Не ПустаяСтрока(УсловиеВТ) Тогда
			УсловиеВТ = УсловиеВТ + " И ";
		КонецЕсли;
		УсловиеВТ = УсловиеВТ + "(Субконто1.Артикул В(&СписокАртикулов) ИЛИ Субконто2.Артикул В(&СписокАртикулов))";
	КонецЕсли;
	
	Если НоменклатураСписок.Количество() > 0 И СписокАртикулов.Количество() = 0 Тогда
		Если Не ПустаяСтрока(УсловиеВТ) Тогда
			УсловиеВТ = УсловиеВТ + " И ";
		КонецЕсли;
		УсловиеВТ = УсловиеВТ + "(Субконто1.Наименование В(&НоменклатураСписок) ИЛИ Субконто2.Наименование В(&НоменклатураСписок))";
	КонецЕсли;
	
	Если СписокАртикулов.Количество() > 0 И НоменклатураСписок.Количество() = 0 Тогда
		Если Не ПустаяСтрока(УсловиеВТ) Тогда
			УсловиеВТ = УсловиеВТ + " И ";
		КонецЕсли;
		УсловиеВТ = УсловиеВТ + "(Субконто1.Артикул В(&СписокАртикулов) ИЛИ Субконто2.Артикул В(&СписокАртикулов))";
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПараметрыВТ", УсловиеВТ);
	Запрос.Текст = ТекстЗапроса;
	
	Если СписокНазванийСкладов.Количество() > 0 Тогда
		Запрос.УстановитьПараметр("СписокНазванийСкладов", СписокНазванийСкладов);
	КонецЕсли;
	
	Если НоменклатураСписок.Количество() > 0 Тогда
		Запрос.УстановитьПараметр("НоменклатураСписок", НоменклатураСписок);
	КонецЕсли;
	
	Если СписокАртикулов.Количество() > 0 Тогда
		Запрос.УстановитьПараметр("СписокАртикулов", СписокАртикулов);
	КонецЕсли;

	Запрос.УстановитьПараметр("Дата", Дата);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаСклад = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаСклад.Следующий() Цикл
		
		СтруктураСклад = Новый Структура("store_name", Строка(ВыборкаСклад.Склад));
		Остатки = Новый Массив;
		
		Выборка = ВыборкаСклад.Выбрать();
	
		Пока Выборка.Следующий() Цикл
			
			СтруктураОстатки = Новый Структура();
			СтруктураОстатки.Вставить("Nomenclature", Строка(Выборка.Номенклатура));
			СтруктураОстатки.Вставить("Article", Выборка.Артикул);
			СтруктураОстатки.Вставить("MeasurementUnit", Строка(Выборка.ЕдиницаИзмерения));
			СтруктураОстатки.Вставить("Quantity", Выборка.Количество);
			СтруктураОстатки.Вставить("Price", Окр(Выборка.Цена));
			СтруктураОстатки.Вставить("TotalCost", Окр(Выборка.Сумма));
			
			Остатки.Добавить(СтруктураОстатки);
			
		КонецЦикла;                              
		
		СтруктураСклад.Вставить("data", Остатки); 
		Склады.Добавить(СтруктураСклад);
		
	КонецЦикла; 
	
	JSONСтрока = API_СлужебныйСервер.ПреобразоватьВJSON(Склады);
	Возврат JSONСтрока;
	
КонецФункции

#КонецОбласти