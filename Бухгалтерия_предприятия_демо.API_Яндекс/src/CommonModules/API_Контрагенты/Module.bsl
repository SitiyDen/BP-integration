#Область ПрограммныйИнтерфейс

// Возвращает данные контрагентов, отфильтрованных по наименованиям, ИНН и КПП, в формате JSON.
//
// Параметры:
//   СписокНаименований - Массив из Строка - список наименований контрагентов для фильтрации
//   СписокИННКонтрагента - Массив из Строка - список ИНН контрагентов для фильтрации
//   СписокКППКонтрагента - Массив из Строка - список КПП контрагентов для фильтрации
//
// Возвращаемое значение:
//   Строка - строка JSON, содержащая массив структур с данными контрагентов
Функция ПолучитьКонтрагентов(СписокНаименований, СписокИННКонтрагента, СписокКППКонтрагента) Экспорт
	
	Контрагенты = Новый Массив;
	
	ВидКИЮридическийАдрес = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента;  	
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Ссылка,
		|	Контрагенты.Наименование КАК Наименование,
		|	Контрагенты.НаименованиеПолное КАК НаименованиеПолное,
		|	Контрагенты.ИНН КАК ИНН,
		|	Контрагенты.КПП КАК КПП,
		|	Контрагенты.КодПоОКПО КАК ОКПО,
		|	Контрагенты.ЮридическоеФизическоеЛицо КАК ЮридическоеФизическоеЛицо,
		|	Контрагенты.НалоговыйНомер КАК НалоговыйНомер,
		|	Контрагенты.РегистрационныйНомер КАК ОГРН,
		|	Контрагенты.ГосударственныйОрган КАК ГосударственныйОрган,
		|	ЕСТЬNULL(Контрагенты.ОсновнойБанковскийСчет.НомерСчета, """") КАК ОсновнойСчет,
		|	ЕСТЬNULL(Контрагенты.ОсновноеКонтактноеЛицо.Наименование, """") КАК ОсновноеКонтактное,
		|	ЕСТЬNULL(БанковскиеСчета.НомерСчета, """") КАК НомерСчета,
		|	ЕСТЬNULL(БанковскиеСчета.Банк.Наименование, """") КАК БанкНаименование,
		|	ЕСТЬNULL(БанковскиеСчета.Банк.СВИФТБИК, """") КАК БанкСВИФТБИК,
		|	ЕСТЬNULL(БанковскиеСчета.Банк.КоррСчет, """") КАК БанкКоррСчет,
		|	ЕСТЬNULL(КонтрагентыКонтактнаяИнформация.Вид, """") КАК ВидКИ,
		|	ЕСТЬNULL(КонтрагентыКонтактнаяИнформация.Представление, """") КАК КИПредставление
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчета КАК БанковскиеСчета
		|		ПО Контрагенты.Ссылка = БанковскиеСчета.Владелец
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|		ПО Контрагенты.Ссылка = КонтрагентыКонтактнаяИнформация.Ссылка
		|ГДЕ
		|	НЕ Контрагенты.ЭтоГруппа
		|ИТОГИ
		|ПО
		|	Ссылка,
		|	БанковскиеСчета.Ссылка";
		
	Условие = "НЕ Контрагенты.ЭтоГруппа";
	
	Если СписокНаименований.Количество() > 0 Тогда
		Условие = Условие + " И Контрагенты.Наименование В (&СписокНаименований)";
		Запрос.УстановитьПараметр("СписокНаименований", СписокНаименований);
	КонецЕсли;
	
	Если СписокИННКонтрагента.Количество() > 0 Тогда
		Условие = Условие + " И Контрагенты.ИНН В (&СписокИННКонтрагента)";
		Запрос.УстановитьПараметр("СписокИННКонтрагента", СписокИННКонтрагента);
	КонецЕсли;
	
	Если СписокКППКонтрагента.Количество() > 0 Тогда
		Условие = Условие + " И Контрагенты.КПП В (&СписокКППКонтрагента)";
		Запрос.УстановитьПараметр("СписокКППКонтрагента", СписокКППКонтрагента);
	КонецЕсли;
		
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "НЕ Контрагенты.ЭтоГруппа", Условие);	
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаСсылка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаСсылка.Следующий() Цикл
		
		Структура = Новый Структура;
		Структура.Вставить("Name", ВыборкаСсылка.Наименование);
		Структура.Вставить("ref", ПолучитьВнешнююНавигационнуюСсылку(, ПолучитьНавигационнуюСсылку(ВыборкаСсылка.Ссылка)));
		Структура.Вставить("Type", Строка(ВыборкаСсылка.ЮридическоеФизическоеЛицо));
		
		ВыборкаНомерСчета = ВыборкаСсылка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		МассивСчетов = Новый Массив;
		
		Пока ВыборкаНомерСчета.Следующий() Цикл
			
			СтруктураСчета = СформироватьСтруктуруСчета(ВыборкаНомерСчета);		
			МассивСчетов.Добавить(СтруктураСчета);
			
			ВыборкаКИ = ВыборкаНомерСчета.Выбрать();
			МассивКонтактнойИнформации = Новый Массив;
			
			Пока ВыборкаКИ.Следующий() Цикл
				
				СтруктураКИ = СформироватьСтруктуруКИ(ВыборкаКИ);
				Если ЗначениеЗаполнено(ВыборкаКИ.ВидКИ) Тогда
					МассивКонтактнойИнформации.Добавить(СтруктураКИ);
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
		СтруктураРеквизитов = СформироватьСтруктуруРеквизитов(ВыборкаСсылка, МассивКонтактнойИнформации, ВидКИЮридическийАдрес);
		
		Структура.Вставить("Requisites", СтруктураРеквизитов);
		Структура.Вставить("BankAccounts", МассивСчетов);
		Структура.Вставить("ContactInformation", МассивКонтактнойИнформации);
		
		Контрагенты.Добавить(Структура);
		
	КонецЦикла;
	
	JSONСтрока = API_СлужебныйСервер.ПреобразоватьВJSON(Контрагенты);
	Возврат JSONСтрока;
	
КонецФункции

// Возвращает расчеты с указанными контрагентами за период в формате JSON
//
// Параметры:
//   СписокКонтрагентов - Массив из СправочникСсылка.Контрагенты - список контрагентов для выборки
//   НачалоПериода - Дата - начало периода выборки
//   КонецПериода - Дата - конец периода выборки
//
// Возвращаемое значение:
//   Строка - JSON-строка с массивом структур расчетов
Функция ПолучитьРасчетыСКонтрагентами(СписокКонтрагентов, НачалоПериода, КонецПериода) Экспорт
	
	СписокСчетов = Новый Массив;
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПоставщикамиИПодрядчиками);
	СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПокупателямиИЗаказчиками);
	
	Контрагенты = Новый Массив;
		
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ХозрасчетныйОстаткиИОбороты.Счет КАК Счет,
		|	ХозрасчетныйОстаткиИОбороты.Субконто1 КАК Контрагент,
		|	ХозрасчетныйОстаткиИОбороты.Субконто2 КАК Договор,
		|	ЕСТЬNULL(ХозрасчетныйОстаткиИОбороты.Субконто2.Номер, """") КАК НомерДоговора,
		|	ЕСТЬNULL(ХозрасчетныйОстаткиИОбороты.Субконто2.Наименование, """") КАК ДоговорНаименование,
		|	ЕСТЬNULL(ХозрасчетныйОстаткиИОбороты.Валюта, ""RUB"") КАК Валюта,
		|	ХозрасчетныйОстаткиИОбороты.СуммаНачальныйОстатокДт КАК СуммаНачальныйОстатокДт,
		|	ХозрасчетныйОстаткиИОбороты.СуммаНачальныйОстатокКт КАК СуммаНачальныйОстатокКт,
		|	ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокДт КАК СуммаКонечныйОстатокДт,
		|	ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстатокКт КАК СуммаКонечныйОстатокКт,
		|	ХозрасчетныйОстаткиИОбороты.СуммаОборотДт КАК СуммаОборотДт,
		|	ХозрасчетныйОстаткиИОбороты.СуммаОборотКт КАК СуммаОборотКт,
		|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаНачальныйОстатокДт КАК ВалютнаяСуммаНачальныйОстатокДт,
		|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаНачальныйОстатокКт КАК ВалютнаяСуммаНачальныйОстатокКт,
		|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаОборотДт КАК ВалютнаяСуммаОборотДт,
		|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаОборотКт КАК ВалютнаяСуммаОборотКт,
		|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаКонечныйОстатокДт КАК ВалютнаяСуммаКонечныйОстатокДт,
		|	ХозрасчетныйОстаткиИОбороты.ВалютнаяСуммаКонечныйОстатокКт КАК ВалютнаяСуммаКонечныйОстатокКт
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&НачалоПериода, &КонецПериода, , , Счет В ИЕРАРХИИ (&СписокСчетов), , ) КАК ХозрасчетныйОстаткиИОбороты
		|ИТОГИ ПО
		|	Контрагент";
		
	Если СписокКонтрагентов.Количество() > 0 Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,
		    "(&СписокСчетов), , )", 
			"(&СписокСчетов), , Субконто1.Наименование В (&СписокКонтрагентов))");

		Запрос.УстановитьПараметр("СписокКонтрагентов", СписокКонтрагентов);

	КонецЕсли;	
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.УстановитьПараметр("СписокСчетов", СписокСчетов);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаКонтрагент = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаКонтрагент.Следующий() Цикл
		
		Структура = Новый Структура;
		Структура.Вставить("Name", Строка(ВыборкаКонтрагент.Контрагент));
	
		Выборка = ВыборкаКонтрагент.Выбрать();
		
		МассивРасчетов = Новый Массив;
			
		Пока Выборка.Следующий() Цикл
			
			СтруктураРасчетов = Новый Структура;
			СтруктураРасчетов.Вставить("Account",        Строка(Выборка.Счет));
			СтруктураРасчетов.Вставить("ContractNumber", Выборка.НомерДоговора);
			СтруктураРасчетов.Вставить("ContractName",   Выборка.ДоговорНаименование);
			СтруктураРасчетов.Вставить("Currency",       Строка(Выборка.Валюта));

			СтруктураРасчетов.Вставить("DebitOpeningBalance",           Выборка.СуммаНачальныйОстатокДт);
			СтруктураРасчетов.Вставить("CreditOpeningBalance",          Выборка.СуммаНачальныйОстатокКт);
			СтруктураРасчетов.Вставить("DebitClosingBalance",           Выборка.СуммаКонечныйОстатокДт);
			СтруктураРасчетов.Вставить("CreditClosingBalance",          Выборка.СуммаКонечныйОстатокКт);
			СтруктураРасчетов.Вставить("DebitTurnover",                 Выборка.СуммаОборотДт);
			СтруктураРасчетов.Вставить("CreditTurnover",                Выборка.СуммаОборотКт);
			СтруктураРасчетов.Вставить("DebitOpeningBalanceCurrency",   Выборка.ВалютнаяСуммаНачальныйОстатокДт);
			СтруктураРасчетов.Вставить("CreditOpeningBalanceCurrency",  Выборка.ВалютнаяСуммаНачальныйОстатокКт);
			СтруктураРасчетов.Вставить("DebitTurnoverCurrency",         Выборка.ВалютнаяСуммаОборотДт);
			СтруктураРасчетов.Вставить("CreditTurnoverCurrency",        Выборка.ВалютнаяСуммаОборотКт);
			СтруктураРасчетов.Вставить("DebitClosingBalanceCurrency",   Выборка.ВалютнаяСуммаКонечныйОстатокДт);
			СтруктураРасчетов.Вставить("CreditClosingBalanceCurrency",  Выборка.ВалютнаяСуммаКонечныйОстатокКт);			
			
			МассивРасчетов.Добавить(СтруктураРасчетов);
			
		КонецЦикла;
		
		Структура.Вставить("Settlements", МассивРасчетов);
		Контрагенты.Добавить(Структура);
		
	КонецЦикла;
	
	JSONСтрока = API_СлужебныйСервер.ПреобразоватьВJSON(Контрагенты);
	Возврат JSONСтрока;
		
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СформироватьСтруктуруСчета(ВыборкаНомерСчета)
	
	СтруктураСчета = Новый Структура;
	СтруктураСчета.Вставить("BankAccount", ВыборкаНомерСчета.НомерСчета);
	СтруктураСчета.Вставить("BankName", ВыборкаНомерСчета.БанкНаименование);
	СтруктураСчета.Вставить("BIK", ВыборкаНомерСчета.БанкСВИФТБИК);
	СтруктураСчета.Вставить("CorrespondentBankAccount", ВыборкаНомерСчета.БанкКоррСчет);
	
	Возврат СтруктураСчета;
	
КонецФункции

// Формирует структуру с информацией о контактной информации из выборки.
//
// Параметры:
//   ВыборкаКИ - ВыборкаИзРезультатаЗапроса - выборка, содержащая данные о контактной информации
//
// Возвращаемое значение:
//   Структура:
//     * Type - Строка - вид контактной информации
//     * Value - Строка - представление контактной информации
Функция СформироватьСтруктуруКИ(ВыборкаКИ)
	
	СтруктураКИ = Новый Структура;
	СтруктураКИ.Вставить("Type", Строка(ВыборкаКИ.ВидКИ));
	СтруктураКИ.Вставить("Value", Строка(ВыборкаКИ.КИПредставление));	
	
	Возврат СтруктураКИ;
	
КонецФункции

// Формирует структуру с реквизитами контрагента для API.
//
// Параметры:
//   ВыборкаСсылка - СправочникСсылка.Контрагенты - Ссылка на контрагента
//   МассивКИ - Массив из Структура - Массив контактных информации
//   ВидКИЮридическийАдрес - СправочникСсылка.ВидыКонтактнойИнформации - Вид контактной информации юридический адрес
//
// Возвращаемое значение:
//   Структура:
//     * Name - Строка - Наименование контрагента
//     * FullName - Строка - Полное наименование контрагента
//     * OGRN - Строка - ОГРН контрагента
//     * INN - Строка - ИНН контрагента
//     * KPP - Строка - КПП контрагента
//     * OKPO - Строка - ОКПО контрагента
//     * PrimaryBankAccount - Строка - Основной банковский счет
//     * Contact - Строка - Основное контактное лицо
Функция СформироватьСтруктуруРеквизитов(ВыборкаСсылка, МассивКИ, ВидКИЮридическийАдрес)
	
	СтруктураРеквизитов = Новый Структура;
	СтруктураРеквизитов.Вставить("Name",               Строка(ВыборкаСсылка.Наименование));
	СтруктураРеквизитов.Вставить("FullName",           Строка(ВыборкаСсылка.НаименованиеПолное));
	СтруктураРеквизитов.Вставить("OGRN",               Строка(ВыборкаСсылка.ОГРН));
	СтруктураРеквизитов.Вставить("INN",                Строка(ВыборкаСсылка.ИНН));
	СтруктураРеквизитов.Вставить("KPP",                Строка(ВыборкаСсылка.КПП));
	СтруктураРеквизитов.Вставить("OKPO",               Строка(ВыборкаСсылка.ОКПО));
	СтруктураРеквизитов.Вставить("PrimaryBankAccount", Строка(ВыборкаСсылка.ОсновнойСчет));
	СтруктураРеквизитов.Вставить("Contact",            Строка(ВыборкаСсылка.ОсновноеКонтактное));
	
	Для Каждого ЭлементКИ Из МассивКИ Цикл
		
		Если ЭлементКИ.Type = Строка(ВидКИЮридическийАдрес) Тогда
			СтруктураРеквизитов.Вставить("Address", ЭлементКИ.Value);
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СтруктураРеквизитов;
	
КонецФункции

#КонецОбласти
